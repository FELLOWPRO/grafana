          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(dr.doc_type, 'Unknown') AS \"Doc Type\",\n  COUNT(*) AS \"Docs\",\n  ROUND((SUM(dr.fields_correct)::numeric * 100) / NULLIF(SUM(dr.fields_total)::numeric, 0), 1) AS \"Accuracy %\",\n  ROUND(AVG(dr.fields_total - dr.fields_correct)::numeric, 2) AS \"Avg Fixes\"\nFROM document_report dr\nJOIN organisation_cache oc ON dr.org_id = oc.id\nWHERE dr.is_deleted = false\n  AND dr.fields_total > 0\n  AND $__timeFilter(dr.created_on)\n  AND oc.name IN ($organization)\nGROUP BY dr.doc_type\nHAVING COUNT(*) >= 5\nORDER BY \"Docs\" DESC",
          "refId": "A"
        }
