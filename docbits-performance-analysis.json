          "rawSql": "SELECT\n  date_trunc('day', dr.created_on) AS time,\n  ROUND((SUM(dr.fields_correct)::numeric * 100) / NULLIF(SUM(dr.fields_total)::numeric, 0), 2) AS accuracy\nFROM document_report dr\nJOIN organisation_cache oc ON dr.org_id = oc.id\nWHERE dr.is_deleted = false\n  AND dr.fields_total > 0\n  AND $__timeFilter(dr.created_on)\n  AND oc.name IN ($organization)\nGROUP BY date_trunc('day', dr.created_on)\nORDER BY time",
