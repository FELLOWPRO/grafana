          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE\n    WHEN d.extraction_time < 10 THEN '1. Fast (0-10s)'\n    WHEN d.extraction_time < 30 THEN '2. Normal (10-30s)'\n    WHEN d.extraction_time < 60 THEN '3. Slow (30-60s)'\n    ELSE '4. Very Slow (60s+)'\n  END AS speed,\n  COUNT(*) AS docs\nFROM documents d\nJOIN organisation_cache oc ON d.org_id = oc.id\nWHERE d.is_deleted = false\n  AND d.extraction_time IS NOT NULL\n  AND d.extraction_time > 0\n  AND $__timeFilter(d.created_on)\n  AND oc.name IN ($organization)\nGROUP BY speed\nORDER BY speed",
          "refId": "A"
        }
      ],
      "title": "Speed Distribution - How Fast Are We?",
      "type": "barchart"
