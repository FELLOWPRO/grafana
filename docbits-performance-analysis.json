          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', d.created_on) AS time,\n  AVG(d.extraction_time) AS avg_extraction,\n  PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY d.extraction_time) AS p90_extraction\nFROM documents d\nJOIN organisation_cache oc ON d.org_id = oc.id\nWHERE d.is_deleted = false\n  AND d.extraction_time IS NOT NULL\n  AND d.extraction_time > 0\n  AND $__timeFilter(d.created_on)\n  AND oc.name IN ($organization)\nGROUP BY date_trunc('hour', d.created_on)\nORDER BY time",
          "refId": "A"
        }
